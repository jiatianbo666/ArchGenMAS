# === ArchGenMAS 环境变量配置示例 ===
# 复制此文件为 backend/.env 并填入你的 API Key

# SiliconFlow API 配置
LLM_API_KEY=sk-your-siliconflow-api-key-here
LLM_BASE_URL=https://api.siliconflow.cn/v1
LLM_MODEL=Qwen/Qwen3.5-35B-A3B
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.3

# 可选：各 Agent 单独指定模型
# REQUIREMENT_MODEL=Qwen/Qwen3.5-35B-A3B
# ARCHITECTURE_MODEL=Qwen/Qwen3.5-35B-A3B
# REVIEW_MODEL=Qwen/Qwen3.5-35B-A3B
# RISK_MODEL=Qwen/Qwen3.5-35B-A3B
# DOCUMENT_MODEL=Qwen/Qwen3.5-35B-A3B

MAX_ITERATIONS=3
CORS_ORIGINS=http://localhost:5173
